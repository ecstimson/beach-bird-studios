---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Premium Web Design Services - Beach Bird Studios"
  description="Custom web design that converts visitors into customers. Performance-optimized, mobile-first websites built for your business success."
  keywords="web design, custom websites, responsive design, mobile-first, conversion optimization, UI/UX design"
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-container">
      <div class="hero-content">
        <h1 class="hero-title">
          Premium Web Design<br>
          <span class="highlight">That Converts</span>
        </h1>
        <p class="hero-subtitle">
          Custom websites that turn visitors into customers. No templates, no shortcuts – 
          just premium design tailored to your brand and optimized for results.
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn-primary">Start Your Project</a>
          <a href="#portfolio" class="btn-secondary">View Our Work</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="design-preview">
          <div class="browser-mockup">
            <div class="browser-bar">
              <div class="browser-dots">
                <span></span><span></span><span></span>
              </div>
            </div>
            <div class="browser-content">
              <div class="mockup-element header"></div>
              <div class="mockup-element content"></div>
              <div class="mockup-element sidebar"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features">
    <div class="container">
      <div class="section-header">
        <h2>What Makes Our Web Design Different</h2>
        <p>Every website we create is built with your business goals in mind</p>
      </div>
      
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🎯</div>
          <h3>Conversion-Focused Design</h3>
          <p>Every element is strategically placed to guide visitors toward taking action. We design for results, not just aesthetics.</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">📱</div>
          <h3>Mobile-First Approach</h3>
          <p>With 60% of web traffic coming from mobile devices, we ensure your site looks and performs perfectly on every screen size.</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Lightning-Fast Performance</h3>
          <p>Page speed affects both user experience and SEO rankings. We optimize every site for maximum performance.</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">🎨</div>
          <h3>Custom Visual Identity</h3>
          <p>Your brand deserves a unique presence online. We create custom designs that reflect your brand personality.</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <h3>Security & Reliability</h3>
          <p>Built with security best practices and reliable hosting to keep your site safe and always accessible.</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Analytics Integration</h3>
          <p>Track what matters with integrated analytics and conversion tracking to measure your success.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="process">
    <div class="container">
      <div class="section-header">
        <h2>Our Web Design Process</h2>
        <p>A proven approach that delivers results every time</p>
      </div>
      
      <div class="process-steps">
        <div class="step">
          <div class="step-number">01</div>
          <div class="step-content">
            <h3>Discovery & Strategy</h3>
            <p>We dive deep into your business, target audience, and goals to create a strategic foundation for your website.</p>
          </div>
        </div>
        
        <div class="step">
          <div class="step-number">02</div>
          <div class="step-content">
            <h3>Design & Prototyping</h3>
            <p>Custom mockups and interactive prototypes that bring your vision to life before development begins.</p>
          </div>
        </div>
        
        <div class="step">
          <div class="step-number">03</div>
          <div class="step-content">
            <h3>Development & Testing</h3>
            <p>Clean, efficient code that's thoroughly tested across all devices and browsers for optimal performance.</p>
          </div>
        </div>
        
        <div class="step">
          <div class="step-number">04</div>
          <div class="step-content">
            <h3>Launch & Optimization</h3>
            <p>Smooth launch with ongoing monitoring and optimization to ensure peak performance and results.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Packages Section -->
  <section class="packages">
    <div class="container">
      <div class="section-header">
        <h2>Web Design Packages</h2>
        <p>Choose the perfect solution for your business needs</p>
      </div>
      
      <div class="packages-grid">
        <div class="package-card">
          <h3>Startup Website</h3>
          <div class="package-price">
            <span class="price">$2,500</span>
            <span class="period">starting</span>
          </div>
          <ul class="package-features">
            <li>✓ 5-page custom design</li>
            <li>✓ Mobile responsive</li>
            <li>✓ Basic SEO optimization</li>
            <li>✓ Contact form integration</li>
            <li>✓ 3 months support</li>
          </ul>
          <a href="/contact" class="package-btn">Get Started</a>
        </div>
        
        <div class="package-card featured">
          <div class="package-badge">Most Popular</div>
          <h3>Business Website</h3>
          <div class="package-price">
            <span class="price">$5,000</span>
            <span class="period">starting</span>
          </div>
          <ul class="package-features">
            <li>✓ 10-page custom design</li>
            <li>✓ Advanced functionality</li>
            <li>✓ CMS integration</li>
            <li>✓ E-commerce ready</li>
            <li>✓ Analytics & tracking</li>
            <li>✓ 6 months support</li>
          </ul>
          <a href="/contact" class="package-btn">Get Started</a>
        </div>
        
        <div class="package-card">
          <h3>Enterprise Solution</h3>
          <div class="package-price">
            <span class="price">Custom</span>
            <span class="period">quote</span>
          </div>
          <ul class="package-features">
            <li>✓ Unlimited pages</li>
            <li>✓ Custom integrations</li>
            <li>✓ Advanced security</li>
            <li>✓ Performance optimization</li>
            <li>✓ Priority support</li>
            <li>✓ 12 months support</li>
          </ul>
          <a href="/contact" class="package-btn">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Get a Website That Actually Works?</h2>
        <p>Let's discuss your project and create a website that drives real business results.</p>
        <a href="/contact" class="btn-primary">Start Your Project Today</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    background: linear-gradient(135deg, var(--background-light) 0%, var(--background-gray) 100%);
    padding: 4rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text-dark);
  }

  .highlight {
    color: var(--primary-color);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-light);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--primary-color);
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .btn-primary:hover {
    background: var(--accent-color);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-dark);
    padding: 1rem 2rem;
    border: 2px solid var(--border-light);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .btn-secondary:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
  }

  /* Browser Mockup */
  .design-preview {
    display: flex;
    justify-content: center;
  }

  .browser-mockup {
    background: white;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    width: 400px;
    overflow: hidden;
  }

  .browser-bar {
    background: #f0f0f0;
    padding: 1rem;
    display: flex;
    align-items: center;
  }

  .browser-dots {
    display: flex;
    gap: 0.5rem;
  }

  .browser-dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ddd;
  }

  .browser-dots span:first-child {
    background: #ff5f57;
  }

  .browser-dots span:nth-child(2) {
    background: #ffbd2e;
  }

  .browser-dots span:last-child {
    background: #28ca42;
  }

  .browser-content {
    padding: 2rem;
    height: 300px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mockup-element {
    background: var(--background-gray);
    border-radius: 4px;
  }

  .mockup-element.header {
    height: 40px;
  }

  .mockup-element.content {
    height: 120px;
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  }

  .mockup-element.sidebar {
    height: 80px;
  }

  /* Features Section */
  .features {
    padding: 6rem 0;
    background: var(--background-light);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .section-header p {
    font-size: 1.2rem;
    color: var(--text-light);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background: white;
    padding: 2.5rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    text-align: center;
    transition: transform 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-5px);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .feature-card h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .feature-card p {
    color: var(--text-light);
    line-height: 1.6;
  }

  /* Process Section */
  .process {
    padding: 6rem 0;
    background: var(--background-gray);
  }

  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .step-number {
    background: var(--primary-color);
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .step-content h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-dark);
  }

  .step-content p {
    color: var(--text-light);
    line-height: 1.6;
  }

  /* Packages Section */
  .packages {
    padding: 6rem 0;
    background: var(--background-light);
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .package-card {
    background: white;
    padding: 3rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    text-align: center;
    position: relative;
    transition: transform 0.3s ease;
  }

  .package-card:hover {
    transform: translateY(-5px);
  }

  .package-card.featured {
    border: 2px solid var(--primary-color);
    transform: scale(1.05);
  }

  .package-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--secondary-color);
    color: var(--accent-color);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .package-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .package-price {
    margin-bottom: 2rem;
  }

  .price {
    font-size: 3rem;
    font-weight: 700;
    color: var(--primary-color);
  }

  .period {
    display: block;
    font-size: 1rem;
    color: var(--text-light);
    margin-top: 0.5rem;
  }

  .package-features {
    list-style: none;
    margin-bottom: 2rem;
    text-align: left;
  }

  .package-features li {
    color: var(--text-light);
    margin-bottom: 0.8rem;
    padding-left: 1rem;
  }

  .package-btn {
    background: var(--primary-color);
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
    width: 100%;
  }

  .package-btn:hover {
    background: var(--accent-color);
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 0;
    background: var(--accent-color);
    color: white;
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: white;
  }

  .cta-content p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-content .btn-primary {
    background: var(--secondary-color);
    color: var(--accent-color);
  }

  .cta-content .btn-primary:hover {
    background: white;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .browser-mockup {
      width: 300px;
    }

    .step {
      flex-direction: column;
      text-align: center;
    }

    .step-number {
      align-self: center;
    }

    .package-card.featured {
      transform: none;
    }
  }
</style>