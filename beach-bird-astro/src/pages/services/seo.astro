---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="SEO Services That Actually Work - Beach Bird Studios"
  description="Strategic SEO that drives organic traffic and delivers measurable business growth. Technical audits, content optimization, and local SEO strategies."
  keywords="SEO services, search engine optimization, organic traffic, local SEO, technical SEO, content optimization, keyword research"
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-container">
      <div class="hero-content">
        <h1 class="hero-title">
          SEO Services<br>
          <span class="highlight">That Actually Work</span>
        </h1>
        <p class="hero-subtitle">
          Strategic search engine optimization that drives real organic traffic and measurable business growth. 
          No black hat tactics, no empty promises – just proven SEO strategies that deliver results.
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn-primary">Get SEO Audit</a>
          <a href="#results" class="btn-secondary">See Results</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="seo-chart">
          <div class="chart-container">
            <div class="chart-bar" style="height: 30%"></div>
            <div class="chart-bar" style="height: 45%"></div>
            <div class="chart-bar" style="height: 70%"></div>
            <div class="chart-bar" style="height: 85%"></div>
            <div class="chart-bar" style="height: 100%"></div>
          </div>
          <div class="chart-label">Organic Traffic Growth</div>
        </div>
        <div class="seo-metrics">
          <div class="metric-card">
            <span class="metric-number">+250%</span>
            <span class="metric-label">Traffic Increase</span>
          </div>
          <div class="metric-card">
            <span class="metric-number">#1</span>
            <span class="metric-label">Rankings Achieved</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services">
    <div class="container">
      <div class="section-header">
        <h2>Our SEO Services</h2>
        <p>Comprehensive search engine optimization that covers all aspects of your online visibility</p>
      </div>
      
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🔍</div>
          <h3>Technical SEO Audit</h3>
          <p>Comprehensive analysis of your website's technical health, identifying and fixing issues that hurt your rankings.</p>
          <ul class="service-features">
            <li>• Site speed optimization</li>
            <li>• Mobile responsiveness check</li>
            <li>• Crawl error identification</li>
            <li>• Schema markup implementation</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">📝</div>
          <h3>Content Optimization</h3>
          <p>Strategic content creation and optimization that targets your ideal keywords and serves your audience.</p>
          <ul class="service-features">
            <li>• Keyword research & strategy</li>
            <li>• Content gap analysis</li>
            <li>• On-page optimization</li>
            <li>• Content calendar planning</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">📍</div>
          <h3>Local SEO</h3>
          <p>Dominate local search results and get found by customers in your area who are ready to buy.</p>
          <ul class="service-features">
            <li>• Google My Business optimization</li>
            <li>• Local citation building</li>
            <li>• Review management</li>
            <li>• Local content strategy</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">🔗</div>
          <h3>Link Building</h3>
          <p>High-quality backlink acquisition from authoritative websites to boost your domain authority and rankings.</p>
          <ul class="service-features">
            <li>• Link opportunity research</li>
            <li>• Guest posting campaigns</li>
            <li>• Broken link building</li>
            <li>• Competitor link analysis</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">📊</div>
          <h3>SEO Analytics & Reporting</h3>
          <p>Transparent reporting and data-driven insights to track progress and optimize performance.</p>
          <ul class="service-features">
            <li>• Ranking tracking</li>
            <li>• Traffic analysis</li>
            <li>• Conversion monitoring</li>
            <li>• Competitive analysis</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">🛠️</div>
          <h3>SEO Strategy & Consulting</h3>
          <p>Personalized SEO strategy development based on your business goals and competitive landscape.</p>
          <ul class="service-features">
            <li>• SEO roadmap creation</li>
            <li>• Competitive research</li>
            <li>• Growth opportunity identification</li>
            <li>• Implementation guidance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="results" id="results">
    <div class="container">
      <div class="section-header">
        <h2>Real Results from Real Clients</h2>
        <p>See the measurable impact of our SEO strategies</p>
      </div>
      
      <div class="results-grid">
        <div class="result-card">
          <div class="result-metric">+350%</div>
          <div class="result-description">
            <h4>Organic Traffic Growth</h4>
            <p>Local law firm saw 350% increase in organic traffic within 8 months, leading to 40+ new client inquiries monthly.</p>
          </div>
        </div>
        
        <div class="result-card">
          <div class="result-metric">#1</div>
          <div class="result-description">
            <h4>Top Rankings Achieved</h4>
            <p>E-commerce client achieved #1 rankings for 15+ competitive keywords, resulting in $200K additional revenue.</p>
          </div>
        </div>
        
        <div class="result-card">
          <div class="result-metric">500%</div>
          <div class="result-description">
            <h4>Local Visibility Boost</h4>
            <p>Restaurant chain increased local search visibility by 500%, driving 30% more foot traffic to locations.</p>
          </div>
        </div>
        
        <div class="result-card">
          <div class="result-metric">85%</div>
          <div class="result-description">
            <h4>Lead Quality Improvement</h4>
            <p>B2B service company improved lead quality by 85% through targeted long-tail keyword optimization.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="process">
    <div class="container">
      <div class="section-header">
        <h2>Our Proven SEO Process</h2>
        <p>A systematic approach that delivers consistent, measurable results</p>
      </div>
      
      <div class="process-timeline">
        <div class="timeline-step">
          <div class="timeline-marker">1</div>
          <div class="timeline-content">
            <h3>SEO Audit & Analysis</h3>
            <p>Comprehensive analysis of your current SEO performance, technical issues, and opportunities for improvement.</p>
            <div class="timeline-deliverables">
              <strong>Deliverables:</strong> Technical audit report, keyword analysis, competitor research
            </div>
          </div>
        </div>
        
        <div class="timeline-step">
          <div class="timeline-marker">2</div>
          <div class="timeline-content">
            <h3>Strategy Development</h3>
            <p>Create a customized SEO strategy aligned with your business goals and target market.</p>
            <div class="timeline-deliverables">
              <strong>Deliverables:</strong> SEO strategy document, keyword roadmap, content calendar
            </div>
          </div>
        </div>
        
        <div class="timeline-step">
          <div class="timeline-marker">3</div>
          <div class="timeline-content">
            <h3>Implementation & Optimization</h3>
            <p>Execute the strategy with on-page optimization, technical improvements, and content creation.</p>
            <div class="timeline-deliverables">
              <strong>Deliverables:</strong> Optimized pages, technical fixes, new content, link building
            </div>
          </div>
        </div>
        
        <div class="timeline-step">
          <div class="timeline-marker">4</div>
          <div class="timeline-content">
            <h3>Monitor & Refine</h3>
            <p>Continuous monitoring of performance with regular adjustments to maximize results.</p>
            <div class="timeline-deliverables">
              <strong>Deliverables:</strong> Monthly reports, performance analysis, strategy refinements
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Packages -->
  <section class="packages">
    <div class="container">
      <div class="section-header">
        <h2>SEO Service Packages</h2>
        <p>Choose the right level of SEO support for your business</p>
      </div>
      
      <div class="packages-grid">
        <div class="package-card">
          <h3>SEO Foundation</h3>
          <div class="package-price">
            <span class="price">$1,500</span>
            <span class="period">per month</span>
          </div>
          <ul class="package-features">
            <li>✓ Technical SEO audit & fixes</li>
            <li>✓ Keyword research & strategy</li>
            <li>✓ On-page optimization (5 pages)</li>
            <li>✓ Monthly reporting</li>
            <li>✓ Email support</li>
          </ul>
          <a href="/contact" class="package-btn">Get Started</a>
        </div>
        
        <div class="package-card featured">
          <div class="package-badge">Most Popular</div>
          <h3>SEO Growth</h3>
          <div class="package-price">
            <span class="price">$3,000</span>
            <span class="period">per month</span>
          </div>
          <ul class="package-features">
            <li>✓ Everything in Foundation</li>
            <li>✓ Content creation (4 articles/month)</li>
            <li>✓ Local SEO optimization</li>
            <li>✓ Link building campaign</li>
            <li>✓ Conversion tracking setup</li>
            <li>✓ Priority phone support</li>
          </ul>
          <a href="/contact" class="package-btn">Get Started</a>
        </div>
        
        <div class="package-card">
          <h3>SEO Domination</h3>
          <div class="package-price">
            <span class="price">$5,000</span>
            <span class="period">per month</span>
          </div>
          <ul class="package-features">
            <li>✓ Everything in Growth</li>
            <li>✓ Content creation (8 articles/month)</li>
            <li>✓ Advanced link building</li>
            <li>✓ Competitor monitoring</li>
            <li>✓ Dedicated account manager</li>
            <li>✓ Weekly strategy calls</li>
          </ul>
          <a href="/contact" class="package-btn">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq">
    <div class="container">
      <div class="section-header">
        <h2>Frequently Asked Questions</h2>
      </div>
      
      <div class="faq-grid">
        <div class="faq-item">
          <h3>How long does it take to see SEO results?</h3>
          <p>Most clients start seeing improvements in 3-4 months, with significant results by month 6-8. SEO is a long-term strategy that builds momentum over time.</p>
        </div>
        
        <div class="faq-item">
          <h3>Do you guarantee first-page rankings?</h3>
          <p>We don't make unrealistic promises. Instead, we focus on driving qualified traffic and improving your overall online visibility through proven strategies.</p>
        </div>
        
        <div class="faq-item">
          <h3>What makes your SEO different?</h3>
          <p>We focus on sustainable, white-hat techniques that provide long-term value. Our approach is data-driven and tailored to your specific business goals.</p>
        </div>
        
        <div class="faq-item">
          <h3>How do you measure SEO success?</h3>
          <p>We track rankings, organic traffic, lead generation, and ultimately ROI. Our monthly reports show exactly how SEO is impacting your business.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Dominate Search Results?</h2>
        <p>Get a free SEO audit and discover how we can increase your organic traffic and leads.</p>
        <a href="/contact" class="btn-primary">Get Your Free SEO Audit</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    background: linear-gradient(135deg, var(--background-light) 0%, var(--background-gray) 100%);
    padding: 4rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text-dark);
  }

  .highlight {
    color: var(--primary-color);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-light);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--primary-color);
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .btn-primary:hover {
    background: var(--accent-color);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-dark);
    padding: 1rem 2rem;
    border: 2px solid var(--border-light);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .btn-secondary:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
  }

  /* SEO Chart */
  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .seo-chart {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    text-align: center;
  }

  .chart-container {
    display: flex;
    align-items: end;
    justify-content: center;
    gap: 0.5rem;
    height: 120px;
    margin-bottom: 1rem;
  }

  .chart-bar {
    width: 20px;
    background: linear-gradient(to top, var(--primary-color), var(--secondary-color));
    border-radius: 2px 2px 0 0;
    animation: grow 2s ease-out;
  }

  @keyframes grow {
    0% { height: 0; }
  }

  .chart-label {
    font-size: 0.9rem;
    color: var(--text-light);
    font-weight: 600;
  }

  .seo-metrics {
    display: flex;
    gap: 1rem;
  }

  .metric-card {
    background: white;
    padding: 1.5rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    text-align: center;
  }

  .metric-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary-color);
  }

  .metric-label {
    display: block;
    font-size: 0.9rem;
    color: var(--text-light);
    margin-top: 0.5rem;
  }

  /* Services Section */
  .services {
    padding: 6rem 0;
    background: var(--background-light);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .section-header p {
    font-size: 1.2rem;
    color: var(--text-light);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background: white;
    padding: 2.5rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    transition: transform 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
  }

  .service-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .service-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .service-card p {
    color: var(--text-light);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .service-features {
    list-style: none;
    color: var(--text-light);
  }

  .service-features li {
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  /* Results Section */
  .results {
    padding: 6rem 0;
    background: var(--background-gray);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .result-card {
    background: white;
    padding: 2.5rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    text-align: center;
  }

  .result-metric {
    font-size: 3rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 1rem;
  }

  .result-description h4 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-dark);
  }

  .result-description p {
    color: var(--text-light);
    line-height: 1.6;
    font-size: 0.9rem;
  }

  /* Process Section */
  .process {
    padding: 6rem 0;
    background: var(--background-light);
  }

  .process-timeline {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .process-timeline::before {
    content: '';
    position: absolute;
    left: 25px;
    top: 50px;
    bottom: 50px;
    width: 2px;
    background: var(--primary-color);
  }

  .timeline-step {
    display: flex;
    gap: 2rem;
    margin-bottom: 3rem;
    position: relative;
  }

  .timeline-marker {
    background: var(--primary-color);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
    z-index: 1;
  }

  .timeline-content {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    flex-grow: 1;
  }

  .timeline-content h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-dark);
  }

  .timeline-content p {
    color: var(--text-light);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .timeline-deliverables {
    font-size: 0.9rem;
    color: var(--text-light);
    padding: 0.8rem;
    background: var(--background-gray);
    border-radius: 6px;
  }

  .timeline-deliverables strong {
    color: var(--text-dark);
  }

  /* Packages Section */
  .packages {
    padding: 6rem 0;
    background: var(--background-gray);
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .package-card {
    background: white;
    padding: 3rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    text-align: center;
    position: relative;
    transition: transform 0.3s ease;
  }

  .package-card:hover {
    transform: translateY(-5px);
  }

  .package-card.featured {
    border: 2px solid var(--primary-color);
    transform: scale(1.05);
  }

  .package-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--secondary-color);
    color: var(--accent-color);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .package-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .package-price {
    margin-bottom: 2rem;
  }

  .price {
    font-size: 3rem;
    font-weight: 700;
    color: var(--primary-color);
  }

  .period {
    display: block;
    font-size: 1rem;
    color: var(--text-light);
    margin-top: 0.5rem;
  }

  .package-features {
    list-style: none;
    margin-bottom: 2rem;
    text-align: left;
  }

  .package-features li {
    color: var(--text-light);
    margin-bottom: 0.8rem;
    padding-left: 1rem;
  }

  .package-btn {
    background: var(--primary-color);
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
    width: 100%;
  }

  .package-btn:hover {
    background: var(--accent-color);
  }

  /* FAQ Section */
  .faq {
    padding: 6rem 0;
    background: var(--background-light);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .faq-item {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 3px 15px rgba(0,0,0,0.05);
  }

  .faq-item h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .faq-item p {
    color: var(--text-light);
    line-height: 1.6;
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 0;
    background: var(--accent-color);
    color: white;
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: white;
  }

  .cta-content p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-content .btn-primary {
    background: var(--secondary-color);
    color: var(--accent-color);
  }

  .cta-content .btn-primary:hover {
    background: white;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .process-timeline::before {
      display: none;
    }

    .timeline-step {
      flex-direction: column;
      text-align: center;
    }

    .timeline-marker {
      align-self: center;
    }

    .package-card.featured {
      transform: none;
    }
  }
</style>