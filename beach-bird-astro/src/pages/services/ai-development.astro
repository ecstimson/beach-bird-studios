---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="AI Development Services - Beach Bird Studios"
  description="Custom AI solutions that automate tasks and enhance user experiences. Chatbots, automation workflows, and intelligent integrations for competitive advantage."
  keywords="AI development, artificial intelligence, chatbots, automation, machine learning, AI integration, intelligent solutions"
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-container">
      <div class="hero-content">
        <h1 class="hero-title">
          AI Development<br>
          <span class="highlight">That Works for You</span>
        </h1>
        <p class="hero-subtitle">
          Harness the power of artificial intelligence to automate tasks, enhance user experiences, 
          and gain a competitive edge. Custom AI solutions tailored to your business needs.
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn-primary">Explore AI Solutions</a>
          <a href="#use-cases" class="btn-secondary">See Use Cases</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="ai-visualization">
          <div class="ai-brain">
            <div class="neural-node"></div>
            <div class="neural-node"></div>
            <div class="neural-node"></div>
            <div class="neural-node"></div>
            <div class="neural-network"></div>
          </div>
          <div class="ai-stats">
            <div class="stat">
              <span class="stat-number">75%</span>
              <span class="stat-label">Time Saved</span>
            </div>
            <div class="stat">
              <span class="stat-number">3x</span>
              <span class="stat-label">Productivity Boost</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services">
    <div class="container">
      <div class="section-header">
        <h2>AI Solutions We Develop</h2>
        <p>Cutting-edge artificial intelligence tailored to your business needs</p>
      </div>
      
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🤖</div>
          <h3>Intelligent Chatbots</h3>
          <p>24/7 customer support with natural language understanding, lead qualification, and seamless human handoff.</p>
          <ul class="service-features">
            <li>• Multi-platform deployment</li>
            <li>• Natural language processing</li>
            <li>• CRM integration</li>
            <li>• Analytics & insights</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">⚡</div>
          <h3>Process Automation</h3>
          <p>Streamline repetitive tasks with intelligent automation that learns and adapts to your workflows.</p>
          <ul class="service-features">
            <li>• Workflow optimization</li>
            <li>• Data processing</li>
            <li>• Email automation</li>
            <li>• Report generation</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">📊</div>
          <h3>Predictive Analytics</h3>
          <p>Make data-driven decisions with AI-powered insights and predictive models for your business.</p>
          <ul class="service-features">
            <li>• Sales forecasting</li>
            <li>• Customer behavior analysis</li>
            <li>• Market trend prediction</li>
            <li>• Risk assessment</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">🎯</div>
          <h3>Personalization Engine</h3>
          <p>Deliver personalized experiences that increase engagement and conversion rates for your customers.</p>
          <ul class="service-features">
            <li>• Content recommendations</li>
            <li>• Dynamic pricing</li>
            <li>• User experience optimization</li>
            <li>• A/B testing integration</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">🔍</div>
          <h3>Document Processing</h3>
          <p>Automatically extract and process information from documents with advanced OCR and NLP capabilities.</p>
          <ul class="service-features">
            <li>• Text extraction</li>
            <li>• Data classification</li>
            <li>• Form processing</li>
            <li>• Document validation</li>
          </ul>
        </div>
        
        <div class="service-card">
          <div class="service-icon">🎤</div>
          <h3>Voice & Speech AI</h3>
          <p>Voice-enabled interfaces and speech recognition systems for hands-free interaction and accessibility.</p>
          <ul class="service-features">
            <li>• Voice commands</li>
            <li>• Speech-to-text</li>
            <li>• Voice assistants</li>
            <li>• Audio transcription</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases Section -->
  <section class="use-cases" id="use-cases">
    <div class="container">
      <div class="section-header">
        <h2>AI in Action: Real-World Applications</h2>
        <p>See how AI transforms businesses across different industries</p>
      </div>
      
      <div class="use-cases-grid">
        <div class="use-case">
          <div class="use-case-icon">🏥</div>
          <h3>Healthcare</h3>
          <div class="use-case-content">
            <h4>Patient Intake Automation</h4>
            <p>Automated patient registration, symptom assessment, and appointment scheduling that reduces wait times by 60%.</p>
          </div>
        </div>
        
        <div class="use-case">
          <div class="use-case-icon">🏪</div>
          <h3>E-commerce</h3>
          <div class="use-case-content">
            <h4>Smart Product Recommendations</h4>
            <p>AI-driven product suggestions that increased average order value by 35% and customer satisfaction by 40%.</p>
          </div>
        </div>
        
        <div class="use-case">
          <div class="use-case-icon">🏢</div>
          <h3>Professional Services</h3>
          <div class="use-case-content">
            <h4>Lead Qualification System</h4>
            <p>Intelligent lead scoring and qualification that improved conversion rates by 45% and reduced sales cycle time.</p>
          </div>
        </div>
        
        <div class="use-case">
          <div class="use-case-icon">🏠</div>
          <h3>Real Estate</h3>
          <div class="use-case-content">
            <h4>Property Matching Engine</h4>
            <p>AI-powered property recommendations based on buyer preferences, increasing qualified showings by 50%.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="benefits">
    <div class="container">
      <div class="section-header">
        <h2>Why Choose AI Development with Beach Bird Studios</h2>
      </div>
      
      <div class="benefits-grid">
        <div class="benefit">
          <div class="benefit-number">01</div>
          <div class="benefit-content">
            <h3>Custom Solutions</h3>
            <p>No off-the-shelf solutions. Every AI implementation is designed specifically for your business needs and goals.</p>
          </div>
        </div>
        
        <div class="benefit">
          <div class="benefit-number">02</div>
          <div class="benefit-content">
            <h3>Seamless Integration</h3>
            <p>We ensure AI solutions work perfectly with your existing systems and workflows without disruption.</p>
          </div>
        </div>
        
        <div class="benefit">
          <div class="benefit-number">03</div>
          <div class="benefit-content">
            <h3>Scalable Architecture</h3>
            <p>Built to grow with your business, our AI solutions can handle increased load and new requirements.</p>
          </div>
        </div>
        
        <div class="benefit">
          <div class="benefit-number">04</div>
          <div class="benefit-content">
            <h3>Ongoing Support</h3>
            <p>Continuous monitoring, updates, and optimization to ensure your AI solutions perform at their best.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Development Process -->
  <section class="development-process">
    <div class="container">
      <div class="section-header">
        <h2>Our AI Development Process</h2>
        <p>From concept to deployment, we guide you through every step</p>
      </div>
      
      <div class="process-timeline">
        <div class="timeline-step">
          <div class="timeline-marker">1</div>
          <div class="timeline-content">
            <h3>Discovery & Analysis</h3>
            <p>We analyze your business processes, identify AI opportunities, and define success metrics.</p>
          </div>
        </div>
        
        <div class="timeline-step">
          <div class="timeline-marker">2</div>
          <div class="timeline-content">
            <h3>Solution Design</h3>
            <p>Create detailed technical specifications and prototype the AI solution architecture.</p>
          </div>
        </div>
        
        <div class="timeline-step">
          <div class="timeline-marker">3</div>
          <div class="timeline-content">
            <h3>Development & Training</h3>
            <p>Build and train AI models using your data with rigorous testing and validation.</p>
          </div>
        </div>
        
        <div class="timeline-step">
          <div class="timeline-marker">4</div>
          <div class="timeline-content">
            <h3>Integration & Launch</h3>
            <p>Seamlessly integrate with your systems and deploy with comprehensive monitoring.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Transform Your Business with AI?</h2>
        <p>Let's explore how artificial intelligence can give you a competitive advantage and drive growth.</p>
        <a href="/contact" class="btn-primary">Start Your AI Journey</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    background: linear-gradient(135deg, var(--background-light) 0%, var(--background-gray) 100%);
    padding: 4rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text-dark);
  }

  .highlight {
    color: var(--primary-color);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-light);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--primary-color);
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .btn-primary:hover {
    background: var(--accent-color);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-dark);
    padding: 1rem 2rem;
    border: 2px solid var(--border-light);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .btn-secondary:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
  }

  /* AI Visualization */
  .ai-visualization {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .ai-brain {
    width: 200px;
    height: 200px;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    border-radius: 50%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  .neural-node {
    width: 20px;
    height: 20px;
    background: white;
    border-radius: 50%;
    position: absolute;
    animation: float 3s infinite ease-in-out;
  }

  .neural-node:nth-child(1) { top: 30px; left: 50%; transform: translateX(-50%); }
  .neural-node:nth-child(2) { top: 80px; left: 30px; animation-delay: -0.5s; }
  .neural-node:nth-child(3) { top: 80px; right: 30px; animation-delay: -1s; }
  .neural-node:nth-child(4) { bottom: 40px; left: 50%; transform: translateX(-50%); animation-delay: -1.5s; }

  @keyframes float {
    0%, 100% { transform: translateY(0) translateX(-50%); }
    50% { transform: translateY(-10px) translateX(-50%); }
  }

  .ai-stats {
    display: flex;
    gap: 2rem;
  }

  .stat {
    text-align: center;
    background: white;
    padding: 1.5rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary-color);
  }

  .stat-label {
    display: block;
    font-size: 0.9rem;
    color: var(--text-light);
    margin-top: 0.5rem;
  }

  /* Services Section */
  .services {
    padding: 6rem 0;
    background: var(--background-light);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .section-header p {
    font-size: 1.2rem;
    color: var(--text-light);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background: white;
    padding: 2.5rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    transition: transform 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
  }

  .service-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .service-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .service-card p {
    color: var(--text-light);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .service-features {
    list-style: none;
    color: var(--text-light);
  }

  .service-features li {
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  /* Use Cases Section */
  .use-cases {
    padding: 6rem 0;
    background: var(--background-gray);
  }

  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .use-case {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    text-align: center;
  }

  .use-case-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .use-case h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .use-case-content h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--primary-color);
  }

  .use-case-content p {
    color: var(--text-light);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Benefits Section */
  .benefits {
    padding: 6rem 0;
    background: var(--background-light);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .benefit {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .benefit-number {
    background: var(--primary-color);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
  }

  .benefit-content h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-dark);
  }

  .benefit-content p {
    color: var(--text-light);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* Development Process */
  .development-process {
    padding: 6rem 0;
    background: var(--background-gray);
  }

  .process-timeline {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .process-timeline::before {
    content: '';
    position: absolute;
    left: 25px;
    top: 50px;
    bottom: 50px;
    width: 2px;
    background: var(--primary-color);
  }

  .timeline-step {
    display: flex;
    gap: 2rem;
    margin-bottom: 3rem;
    position: relative;
  }

  .timeline-marker {
    background: var(--primary-color);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
    z-index: 1;
  }

  .timeline-content {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    flex-grow: 1;
  }

  .timeline-content h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-dark);
  }

  .timeline-content p {
    color: var(--text-light);
    line-height: 1.6;
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 0;
    background: var(--accent-color);
    color: white;
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: white;
  }

  .cta-content p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-content .btn-primary {
    background: var(--secondary-color);
    color: var(--accent-color);
  }

  .cta-content .btn-primary:hover {
    background: white;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .benefit {
      flex-direction: column;
      text-align: center;
    }

    .benefit-number {
      align-self: center;
    }

    .process-timeline::before {
      display: none;
    }

    .timeline-step {
      flex-direction: column;
      text-align: center;
    }

    .timeline-marker {
      align-self: center;
    }
  }
</style>