---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Healthcare Web Design Services - HIPAA Compliant Medical Websites"
  description="Specialized healthcare web design services. HIPAA-compliant websites for medical practices, hospitals, and healthcare providers. Patient-focused design that builds trust."
  keywords="healthcare web design, medical website design, HIPAA compliant websites, patient portal development, medical practice marketing"
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-container">
      <div class="hero-content">
        <h1 class="hero-title">
          Healthcare Web Design<br>
          <span class="highlight">That Builds Trust</span>
        </h1>
        <p class="hero-subtitle">
          HIPAA-compliant websites designed specifically for healthcare providers. 
          Build patient trust, streamline appointments, and grow your practice online.
        </p>
        <div class="hero-features">
          <div class="feature">✓ HIPAA Compliant</div>
          <div class="feature">✓ Patient Portal Integration</div>
          <div class="feature">✓ Appointment Scheduling</div>
          <div class="feature">✓ Mobile Optimized</div>
        </div>
        <div class="hero-cta">
          <a href="/contact" class="btn-primary">Get Healthcare Website Quote</a>
          <a href="#case-studies" class="btn-secondary">View Medical Websites</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="medical-dashboard">
          <div class="dashboard-header">
            <div class="logo-placeholder">🏥 Medical Center</div>
            <div class="nav-items">
              <span>Services</span>
              <span>Doctors</span>
              <span>Portal</span>
            </div>
          </div>
          <div class="dashboard-content">
            <div class="appointment-card">
              <h4>Schedule Appointment</h4>
              <div class="form-elements">
                <div class="form-element"></div>
                <div class="form-element short"></div>
              </div>
              <div class="cta-button">Book Now</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Healthcare Challenges -->
  <section class="challenges">
    <div class="container">
      <div class="section-header">
        <h2>Healthcare Web Design Challenges We Solve</h2>
        <p>Understanding the unique needs of medical practices and healthcare organizations</p>
      </div>
      
      <div class="challenges-grid">
        <div class="challenge-card">
          <div class="challenge-icon">🔒</div>
          <h3>HIPAA Compliance</h3>
          <p>Ensuring patient data security and regulatory compliance with proper encryption, secure forms, and data handling protocols.</p>
        </div>
        
        <div class="challenge-card">
          <div class="challenge-icon">📅</div>
          <h3>Online Scheduling</h3>
          <p>Streamlining appointment bookings with integrated scheduling systems that sync with your practice management software.</p>
        </div>
        
        <div class="challenge-card">
          <div class="challenge-icon">👥</div>
          <h3>Patient Trust</h3>
          <p>Building credibility through professional design, provider credentials, patient testimonials, and transparent communication.</p>
        </div>
        
        <div class="challenge-card">
          <div class="challenge-icon">📱</div>
          <h3>Mobile Experience</h3>
          <p>Optimizing for mobile users who need quick access to contact info, directions, and appointment scheduling on-the-go.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Healthcare Solutions -->
  <section class="solutions">
    <div class="container">
      <div class="section-header">
        <h2>Our Healthcare Web Solutions</h2>
      </div>
      
      <div class="solutions-grid">
        <div class="solution-card">
          <h3>Patient Portal Development</h3>
          <p>Secure patient portals for accessing medical records, test results, prescription refills, and direct communication with providers.</p>
          <ul>
            <li>• Secure login and authentication</li>
            <li>• Medical record access</li>
            <li>• Appointment scheduling</li>
            <li>• Billing and insurance</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <h3>Appointment Scheduling Systems</h3>
          <p>Integrated online booking systems that reduce phone calls and improve patient convenience while syncing with your EHR.</p>
          <ul>
            <li>• Real-time availability</li>
            <li>• Automated confirmations</li>
            <li>• Reminder notifications</li>
            <li>• Waitlist management</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <h3>Telemedicine Integration</h3>
          <p>Secure video consultation platforms integrated into your website for remote patient care and follow-up appointments.</p>
          <ul>
            <li>• HIPAA-compliant video calls</li>
            <li>• Screen sharing capabilities</li>
            <li>• Digital prescriptions</li>
            <li>• Session recording (when permitted)</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <h3>Medical SEO & Marketing</h3>
          <p>Specialized SEO strategies for healthcare providers to attract new patients and build online reputation.</p>
          <ul>
            <li>• Local medical SEO</li>
            <li>• Google My Business optimization</li>
            <li>• Medical content marketing</li>
            <li>• Online review management</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="case-studies" id="case-studies">
    <div class="container">
      <div class="section-header">
        <h2>Healthcare Success Stories</h2>
        <p>Real results from medical practices we've helped grow online</p>
      </div>
      
      <div class="case-studies-grid">
        <div class="case-study">
          <div class="case-study-image">🏥</div>
          <h3>Family Practice Group</h3>
          <div class="case-stats">
            <div class="stat">
              <span class="stat-number">300%</span>
              <span class="stat-label">Online Appointments</span>
            </div>
            <div class="stat">
              <span class="stat-number">45%</span>
              <span class="stat-label">New Patients</span>
            </div>
          </div>
          <p>Implemented patient portal and online scheduling system, resulting in significant reduction in phone calls and improved patient satisfaction.</p>
        </div>
        
        <div class="case-study">
          <div class="case-study-image">🦷</div>
          <h3>Dental Practice</h3>
          <div class="case-stats">
            <div class="stat">
              <span class="stat-number">200%</span>
              <span class="stat-label">Website Traffic</span>
            </div>
            <div class="stat">
              <span class="stat-number">60%</span>
              <span class="stat-label">More Consultations</span>
            </div>
          </div>
          <p>SEO-optimized website with virtual consultations led to dramatic increase in cosmetic dentistry inquiries and bookings.</p>
        </div>
        
        <div class="case-study">
          <div class="case-study-image">🩺</div>
          <h3>Specialty Clinic</h3>
          <div class="case-stats">
            <div class="stat">
              <span class="stat-number">150%</span>
              <span class="stat-label">Referral Increase</span>
            </div>
            <div class="stat">
              <span class="stat-number">90%</span>
              <span class="stat-label">Patient Satisfaction</span>
            </div>
          </div>
          <p>Professional website with provider credentials and patient education resources established clinic as area leader in specialty care.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Compliance & Security -->
  <section class="compliance">
    <div class="container">
      <div class="section-header">
        <h2>HIPAA Compliance & Security</h2>
        <p>Your patients' privacy and data security are our top priorities</p>
      </div>
      
      <div class="compliance-features">
        <div class="compliance-item">
          <div class="compliance-icon">🛡️</div>
          <h3>End-to-End Encryption</h3>
          <p>All patient data transmitted through your website is encrypted using industry-standard SSL/TLS protocols.</p>
        </div>
        
        <div class="compliance-item">
          <div class="compliance-icon">🔐</div>
          <h3>Secure Forms</h3>
          <p>Patient intake forms and contact forms are designed with HIPAA compliance in mind, ensuring data protection.</p>
        </div>
        
        <div class="compliance-item">
          <div class="compliance-icon">📋</div>
          <h3>BAA Agreements</h3>
          <p>We provide Business Associate Agreements (BAA) as required by HIPAA regulations for healthcare websites.</p>
        </div>
        
        <div class="compliance-item">
          <div class="compliance-icon">🔄</div>
          <h3>Regular Security Updates</h3>
          <p>Ongoing security monitoring and updates to protect against emerging threats and vulnerabilities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Improve Your Healthcare Practice Online?</h2>
        <p>Let's discuss your specific needs and create a HIPAA-compliant website that grows your practice.</p>
        <a href="/contact" class="btn-primary">Schedule Healthcare Consultation</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Industry-specific styling for healthcare */
  :root {
    --healthcare-primary: #2c5aa0;
    --healthcare-secondary: #4a90a4;
    --healthcare-accent: #83c5be;
  }

  .hero {
    background: linear-gradient(135deg, var(--background-light) 0%, #f0f8ff 100%);
    padding: 4rem 0 6rem;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text-dark);
  }

  .highlight {
    color: var(--healthcare-primary);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-light);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .feature {
    color: var(--healthcare-primary);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--healthcare-primary);
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background: var(--healthcare-secondary);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--healthcare-primary);
    padding: 1rem 2rem;
    border: 2px solid var(--healthcare-primary);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background: var(--healthcare-primary);
    color: white;
  }

  .medical-dashboard {
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
  }

  .dashboard-header {
    background: var(--healthcare-primary);
    color: white;
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-placeholder {
    font-weight: 600;
  }

  .nav-items {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .dashboard-content {
    padding: 2rem;
  }

  .appointment-card {
    background: var(--background-gray);
    padding: 1.5rem;
    border-radius: 8px;
  }

  .appointment-card h4 {
    margin-bottom: 1rem;
    color: var(--healthcare-primary);
  }

  .form-elements {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .form-element {
    height: 12px;
    background: #ddd;
    border-radius: 4px;
  }

  .form-element.short {
    width: 60%;
  }

  .cta-button {
    background: var(--healthcare-primary);
    color: white;
    padding: 0.8rem 1.5rem;
    border-radius: 6px;
    text-align: center;
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* Section Styling */
  .challenges, .solutions {
    padding: 6rem 0;
  }

  .challenges {
    background: var(--background-light);
  }

  .solutions {
    background: var(--background-gray);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .section-header p {
    font-size: 1.2rem;
    color: var(--text-light);
  }

  .challenges-grid, .solutions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .challenge-card, .solution-card {
    background: white;
    padding: 2.5rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    transition: transform 0.3s ease;
  }

  .challenge-card:hover, .solution-card:hover {
    transform: translateY(-5px);
  }

  .challenge-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .challenge-card h3, .solution-card h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--healthcare-primary);
  }

  .challenge-card p, .solution-card p {
    color: var(--text-light);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .solution-card ul {
    list-style: none;
    color: var(--text-light);
  }

  .solution-card ul li {
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  /* Case Studies */
  .case-studies {
    padding: 6rem 0;
    background: var(--background-light);
  }

  .case-studies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .case-study {
    background: white;
    padding: 2.5rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    text-align: center;
  }

  .case-study-image {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .case-study h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: var(--healthcare-primary);
  }

  .case-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .stat {
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--healthcare-primary);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-light);
  }

  .case-study p {
    color: var(--text-light);
    line-height: 1.6;
  }

  /* Compliance Section */
  .compliance {
    padding: 6rem 0;
    background: var(--background-gray);
  }

  .compliance-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .compliance-item {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    text-align: center;
  }

  .compliance-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .compliance-item h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--healthcare-primary);
  }

  .compliance-item p {
    color: var(--text-light);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 0;
    background: var(--healthcare-primary);
    color: white;
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .cta-content p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-content .btn-primary {
    background: white;
    color: var(--healthcare-primary);
  }

  .cta-content .btn-primary:hover {
    background: var(--healthcare-accent);
    color: var(--healthcare-primary);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-features {
      grid-template-columns: 1fr;
    }

    .case-stats {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>