---
export interface Props {
  title: string;
  tagline?: string;
  description: string;
  features: string[];
  href: string;
  ctaText?: string;
  icon: string;
  featured?: boolean;
}

const {
  title,
  tagline,
  description,
  features = [],
  href,
  ctaText = 'Learn More',
  icon,
  featured = false
} = Astro.props;
---

<div class={featured ? 'brand-card-featured rounded-2xl p-8' : 'brand-card-standard rounded-2xl p-8'}>
  <div class={`w-14 h-14 ${featured ? 'bg-white/20' : 'bg-gradient-to-br from-peach-100 to-gold-100'} rounded-xl flex items-center justify-center mb-6`}>
    <i data-lucide={icon} class={`w-7 h-7 ${featured ? 'text-white' : 'text-peach-500'}`}></i>
  </div>
  
  <h3 class={`text-2xl font-bold ${featured ? 'text-white' : 'text-gray-900'} mb-2`}>
    {title}
  </h3>
  
  {tagline && (
    <p class={`text-lg font-semibold ${featured ? 'text-gold-300' : 'text-peach-600'} mb-4`}>
      {tagline}
    </p>
  )}
  
  <p class={`${featured ? 'text-white/90' : 'text-gray-600'} mb-6`}>
    {description}
  </p>
  
  {features.length > 0 && (
    <ul class="space-y-3 mb-8">
      {features.map((feature) => (
        <li class="flex items-start">
          <i data-lucide="check-circle" class={`w-5 h-5 ${featured ? 'text-gold-300' : 'text-peach-500'} mr-3 flex-shrink-0 mt-0.5`}></i>
          <span class={featured ? 'text-white/90' : 'text-gray-700'}>{feature}</span>
        </li>
      ))}
    </ul>
  )}
  
  <a 
    href={href}
    class={`w-full ${featured ? 'btn-brand-primary' : 'btn-brand-secondary'} flex items-center justify-center`}
  >
    {ctaText}
    <i data-lucide="arrow-right" class="w-4 h-4 ml-2"></i>
  </a>
</div>