---
import StructuredData from '../components/StructuredData.astro';

// Prerender all pages using this layout (except API routes)
export const prerender = true;

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  structuredDataType?: 'LocalBusiness' | 'WebPage' | 'BreadcrumbList' | 'FAQPage' | 'Service';
  structuredData?: any;
}

const { 
  title, 
  description = 'Beach Bird Studios - Premium Websites & SEO That Actually Work', 
  ogImage = '/og-image.jpg',
  structuredDataType = 'WebPage',
  structuredData = {}
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/images/Icon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <!-- Preload Critical Fonts -->
    <link rel="preload" href="/fonts/Chillax-Variable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/Synonym-Variable.woff2" as="font" type="font/woff2" crossorigin>
    
    <!-- Brand Fonts -->
    <link rel="stylesheet" href="/fonts/chillax.css">
    <link rel="stylesheet" href="/fonts/synonym.css">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    
    <!-- Structured Data -->
    <StructuredData 
      type={structuredDataType} 
      data={{ 
        title, 
        description, 
        ...structuredData 
      }} 
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  
  /* Global styles that apply to ALL pages */
  /* Section styling to replace gray-white-gray pattern */
  .section {
    padding: 4rem 2rem;
    position: relative;
    overflow: hidden;
  }
  
  .section:nth-child(odd) {
    background: linear-gradient(135deg, 
      var(--color-peach-50, #fef7f0) 0%, 
      var(--color-gold-50, #fffbeb) 100%);
  }
  
  .section:nth-child(even) {
    background: radial-gradient(ellipse at top, 
      var(--color-gold-50, #fffbeb) 0%, 
      transparent 70%),
      var(--color-peach-50, #fef7f0);
  }
  
  /* Ensure consistent background for all pages */
  body {
    background: linear-gradient(135deg, 
      var(--color-peach-50, #fef7f0) 0%, 
      var(--color-gold-50, #fffbeb) 100%);
    min-height: 100vh;
  }
  
  /* Professional card styling for all pages */
  .card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 2rem;
    box-shadow: 
      0 4px 6px rgba(240, 133, 68, 0.1),
      0 10px 20px rgba(240, 133, 68, 0.05);
    transition: all 0.3s ease;
  }
  
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 
      0 8px 12px rgba(240, 133, 68, 0.15),
      0 20px 40px rgba(251, 191, 36, 0.1);
  }
</style>

<script is:inline>
  // Initialize Lucide icons on page load
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  });
  
  // Re-initialize after Astro page transitions
  document.addEventListener('astro:page-load', () => {
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  });
  
  // Also run after a short delay to catch any icons loaded after DOM ready
  setTimeout(() => {
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  }, 100);
</script>